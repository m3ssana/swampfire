{
  "name": "swampfire",
  "productName": "Swampfire Protocol",
  "main": "index.html",
  "type": "module",
  "window": {
    "title": "Swampfire Protocol",
    "width": 800,
    "height": 600,
    "fullscreen": false,
    "toolbar": false,
    "icon": "customIcon.png"
  },
  "version": "0.0.1",
  "description": "Top-down speed scavenger set in Land O' Lakes, FL 34639",
  "repository": {
    "url": "https://github.com/phaserjs/phaser-by-example"
  },
  "license": "MIT",
  "keywords": [
    "phaser",
    "games",
    "book",
    "pello"
  ],
  "scripts": {
    "dev": "vite --config vite/config.dev.mjs",
    "build": "vite build --config vite/config.prod.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:debug": "DEBUG=1 playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "jsdom": "^28.1.0",
    "terser": "^5.28.1",
    "vite": "^5.1.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "phaser": "^3.80.1",
    "phaser-matter-collision-plugin": "^1.0.0"
  }
}
